# ============================================================
# Agentise Leads — Variáveis de Ambiente
# Boilerplate open source self-hosted
# ============================================================
#
# Este arquivo lista TODAS as variáveis de ambiente que o projeto usa.
# Copie para .env (ou .env.local) e preencha com seus valores reais para
# desenvolvimento local. Para deploy em produção, configure cada variável
# no painel correto:
#
#   - Frontend (VITE_*):  Vercel → Settings → Environment Variables
#   - Edge Functions:     Supabase Dashboard → Project Settings → Edge Functions → Secrets
#   - Scripts/Actions:    GitHub repo → Settings → Secrets and variables → Actions
#
# Veja README.md para o passo a passo completo.

# ============================================================
# 1) FRONTEND (Vercel Environment Variables)
# ============================================================
# Variáveis com prefixo VITE_ são lidas pelo bundler do Vite e expostas ao
# browser. NUNCA coloque secret aqui — apenas valores públicos.

# URL do seu projeto Supabase (obrigatória).
# Encontre em: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima pública do Supabase (obrigatória).
# A anon key é pública por design — RLS é o que protege os dados.
# Encontre em: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Defaults exibidos nos formulários de campanha (opcionais — não-sensíveis).
# Trocar aqui altera o default da UI; a Edge Function que envia o e-mail
# usa as secrets do bloco 2 abaixo, não estes.
VITE_RESEND_FROM_EMAIL=
VITE_RESEND_FROM_NAME=
VITE_WHATSAPP_LINK=

# ============================================================
# 2) EDGE FUNCTIONS SECRETS (Supabase Dashboard)
# ============================================================
# Configure cada uma em:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# Não coloque essas vars no .env do frontend — elas vivem só no Supabase
# e são lidas em runtime via Deno.env.get(...).
#
# As linhas abaixo ficam comentadas neste arquivo apenas como referência da
# lista completa de secrets necessárias.

# CNPJá — consulta de CNPJ + quadro societário.
# Obtenha em: https://cnpja.com (Dashboard → API Keys)
# CNPJA_API_KEY=

# Apollo.io — enriquecimento de sócios (email, LinkedIn, cargo, telefone).
# Obtenha em: https://app.apollo.io/#/settings/integrations/api
# APOLLO_API_KEY=

# Resend — disparo de e-mails transacionais.
# Obtenha em: https://resend.com/api-keys
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_FROM_NAME=

# Chatwoot — gestão de respostas e remoção automática de leads.
# Obtenha em: Chatwoot Dashboard → Profile → Access Token
# CHATWOOT_URL=
# CHATWOOT_API_TOKEN=
# CHATWOOT_ACCOUNT_ID=
# CHATWOOT_INBOX_ID=

# Link WhatsApp usado nos templates de e-mail (substitui {{link_whatsapp}}).
# WHATSAPP_LINK=

# Variáveis injetadas automaticamente pela plataforma Supabase nas Edge
# Functions — listadas aqui apenas como referência, NÃO precisam ser
# configuradas manualmente:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# SUPABASE_ANON_KEY=eyJhbGci...

# ============================================================
# 3) SCRIPTS LOCAIS (opcional, modo manual)
# ============================================================
# Necessárias apenas para o caminho manual do setup (ver README.md):
#   - supabase link --project-ref $SUPABASE_PROJECT_REF
#   - supabase db push (aplica migrations)
#   - supabase functions deploy (deploya Edge Functions)
#
# O caminho recomendado é via Claude Code + BOOTSTRAP.md, que coleta esses
# valores na sessão sem precisar gravá-los em arquivo.

# Personal Access Token do Supabase.
# Crie em: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...

# Project Reference do seu projeto Supabase.
# Encontre em: Supabase Dashboard → Project Settings → General → Reference ID
# SUPABASE_PROJECT_REF=
