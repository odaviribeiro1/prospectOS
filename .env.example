# Agentise Leads — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais.
#
# Convenção:
#   - Variáveis com prefixo VITE_ são lidas pelo bundler do Vite e expostas ao
#     browser (são públicas — nunca coloque secret aqui).
#   - Variáveis SEM o prefixo VITE_ são lidas apenas em runtime das Edge
#     Functions (Deno.env.get) e nunca chegam ao browser.

# ============================================================
# 1) Supabase (frontend) — obrigatórias
# ------------------------------------------------------------
# Conexão do app React com o backend Supabase. A anon key é pública por design
# (RLS é o que protege os dados); a service role key NUNCA vai aqui.
# ============================================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ============================================================
# 2) Defaults de exibição (frontend) — não-sensíveis
# ------------------------------------------------------------
# Usados como valores iniciais nos formulários de campanhas e templates.
# Trocar aqui altera o default exibido na UI; a Edge Function que envia o
# e-mail usa os valores do bloco (3) abaixo, não estes.
# ============================================================
VITE_RESEND_FROM_EMAIL=
VITE_RESEND_FROM_NAME=
VITE_WHATSAPP_LINK=

# ============================================================
# 3) Edge Functions (backend) — sensíveis
# ------------------------------------------------------------
# Estas variáveis NÃO entram no .env.local do frontend. Configure-as no
# Dashboard do Supabase em Settings > Edge Functions > Environment Variables,
# ou via CLI:
#
#   supabase secrets set CNPJA_API_KEY=...
#   supabase secrets set APOLLO_API_KEY=...
#   ...
#
# As linhas abaixo são apenas referência da lista completa de secrets
# necessárias — mantenha-as comentadas neste arquivo.
# ============================================================
# CNPJA_API_KEY=
# APOLLO_API_KEY=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# RESEND_FROM_NAME=
# CHATWOOT_URL=
# CHATWOOT_API_TOKEN=
# CHATWOOT_ACCOUNT_ID=
# CHATWOOT_INBOX_ID=
# WHATSAPP_LINK=

# Supabase Edge Functions runtime (já injetadas automaticamente pela plataforma
# — não precisam ser configuradas manualmente, listadas aqui apenas como
# referência):
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
